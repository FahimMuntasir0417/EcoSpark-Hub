<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Continue with Google</title>
    <meta name="robots" content="noindex,nofollow" />
    <style>
      :root{
        --bg:#f6f7fb;
        --card:#ffffff;
        --text:#111827;
        --muted:#6b7280;
        --border:#e5e7eb;
        --shadow:0 12px 40px rgba(17,24,39,.10);
      }
      *{box-sizing:border-box}
      body{
        margin:0;
        min-height:100vh;
        display:grid;
        place-items:center;
        padding:24px;
        background:var(--bg);
        color:var(--text);
        font-family:system-ui,-apple-system,Segoe UI,Roboto,Helvetica,Arial,sans-serif;
      }
      .card{
        width:min(520px, 100%);
        background:var(--card);
        border:1px solid var(--border);
        border-radius:18px;
        box-shadow:var(--shadow);
        padding:22px;
      }
      .header{
        display:flex;
        align-items:center;
        justify-content:space-between;
        gap:12px;
        margin-bottom:12px;
      }
      .title{
        margin:0;
        font-size:18px;
        line-height:1.3;
        letter-spacing:-0.01em;
      }
      .badge{
        font-size:12px;
        color:var(--muted);
        padding:6px 10px;
        border:1px solid var(--border);
        border-radius:999px;
        background:#fafafa;
      }
      .row{
        display:flex;
        align-items:center;
        gap:12px;
        margin-top:10px;
      }
      .spinner{
        width:18px;height:18px;border-radius:50%;
        border:2px solid var(--border);
        border-top-color:var(--text);
        animation:spin .9s linear infinite;
      }
      @keyframes spin{to{transform:rotate(360deg)}}
      .msg{
        margin:0;
        font-size:14px;
        line-height:1.6;
        color:var(--muted);
      }
      .error{
        margin-top:14px;
        padding:12px 12px;
        border-radius:12px;
        border:1px solid #fecaca;
        background:#fff1f2;
        color:#9f1239;
        font-size:13px;
        line-height:1.6;
        display:none;
        white-space:pre-wrap;
        word-break:break-word;
      }
      .help{
        margin-top:14px;
        font-size:12px;
        color:var(--muted);
      }
      .link{
        color:inherit;
        text-decoration:underline;
        text-underline-offset:3px;
      }
      .footer{
        margin-top:14px;
        font-size:12px;
        color:#9ca3af;
      }
    </style>
  </head>

  <body>
    <main class="card" role="main" aria-live="polite">
      <div class="header">
        <h1 class="title">Redirecting to Google</h1>
        <span class="badge">Secure sign-in</span>
      </div>

      <div class="row">
        <div class="spinner" aria-hidden="true"></div>
        <p id="status" class="msg">Please wait while we connect you to Google…</p>
      </div>

      <div id="errorBox" class="error"></div>

      <noscript>
        <div class="error" style="display:block;border-color:#fde68a;background:#fffbeb;color:#92400e;">
          JavaScript is required to continue. Please enable it and refresh this page.
        </div>
      </noscript>

      <div class="help">
        If nothing happens, <a class="link" href="<%= callbackURL %>">go back</a> and try again.
      </div>

      <div class="footer">You can safely close this tab after the redirect completes.</div>
    </main>

    <script>
      (async () => {
        const statusEl = document.getElementById("status");
        const errorBox = document.getElementById("errorBox");
        const authSignInUrl = <%- authSignInUrlJson %>;
        const callbackURL = <%- callbackURLJson %>;

        const showError = (message) => {
          statusEl.textContent = "We couldn’t redirect you to Google.";
          errorBox.style.display = "block";
          errorBox.textContent = message;
        };

        try {
          const res = await fetch(authSignInUrl, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            credentials: "include",
            body: JSON.stringify({
              provider: "google",
              callbackURL,
            }),
          });

          // Handle non-2xx
          if (!res.ok) {
            let details = "";
            try {
              const text = await res.text();
              details = text ? `\n\nDetails: ${text}` : "";
            } catch {}
            return showError(`Request failed (${res.status} ${res.statusText}).${details}`);
          }

          const data = await res.json().catch(() => null);

          if (data && typeof data.url === "string" && data.url.length > 0) {
            statusEl.textContent = "Taking you to Google…";
            window.location.assign(data.url);
            return;
          }

          showError("The server did not return a redirect URL. Please try again.");
        } catch (err) {
          const msg =
            err instanceof Error ? err.message : "Unexpected error occurred.";
          showError(msg);
        }
      })();
    </script>
  </body>
</html>
