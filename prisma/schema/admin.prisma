model Admin {
  id            String  @id
  name          String
  email         String  @unique
  profileImage  String?
  contactNumber String?

  isDeleted Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([isDeleted])
  @@map("admin")
}
