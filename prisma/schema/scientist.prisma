model Scientist {
  id String @id @default(cuid())

  profilePhoto  String?
  contactNumber String?
  address       String?
  isDeleted     Boolean   @default(false)
  deletedAt     DateTime?

  institution       String? @db.VarChar(150)
  department        String? @db.VarChar(150)
  specialization    String? @db.VarChar(150)
  researchInterests String? @db.Text
  yearsOfExperience Int?
  qualification     String? @db.VarChar(150)
  linkedinUrl       String? @db.VarChar(500)
  googleScholarUrl  String? @db.VarChar(500)
  orcid             String? @unique @db.VarChar(19)

  verifiedAt   DateTime?
  verifiedById String?
  verifiedBy   User?     @relation("ScientistVerifiedBy", fields: [verifiedById], references: [id], onDelete: SetNull)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  scientistSpecialties ScientistSpecialty[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isDeleted], name: "idx_scientist_is_deleted")
  @@index([verifiedById], name: "idx_scientist_verified_by_id")
  @@map("scientists")
}
