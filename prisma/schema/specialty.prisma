model Specialty {
  id          String  @id @default(uuid(7))
  title       String  @unique @db.VarChar(100)
  description String? @db.Text
  icon        String? @db.VarChar(255)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean   @default(false)
  deletedAt DateTime?

  scientistSpecialties ScientistSpecialty[]

  @@index([isDeleted], name: "idx_specialty_is_deleted")
  @@map("specialties")
}

model ScientistSpecialty {
  scientistId String
  specialtyId String

  scientist Scientist @relation(fields: [scientistId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  specialty Specialty @relation(fields: [specialtyId], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@id([scientistId, specialtyId])
  @@index([scientistId], name: "idx_scientist_specialty_scientist_id")
  @@index([specialtyId], name: "idx_scientist_specialty_specialty_id")
  @@map("scientist_specialties")
}
